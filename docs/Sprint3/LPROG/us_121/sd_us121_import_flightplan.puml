@startuml sd_us121_import_flightplan
title US121 — Create a Valid Flight Plan from a File

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "Pilot" as actor
participant ":ImportFlightPlanFromFileUI" as ui <<presentation>>
participant ":ImportFlightPlanFromFileController" as ctrl <<application>>
participant ":AuthorizationService" as authz <<framework>>
participant ":FlightPlanRunner" as runner <<dsl>>
participant ":FlightPlanAssembler" as assembler <<service>>
participant ":AirportRepository" as aptRepo <<persistence>>
participant ":AircraftRepository" as acRepo <<persistence>>
participant ":PilotRepository" as pilotRepo <<persistence>>
participant ":FlightRouteRepository" as routeRepo <<persistence>>
participant "flight:Flight" as flight <<domain>>
participant ":FlightRepository" as fpRepo <<persistence>>

actor -> ui : import flight plan from file
activate ui

ui -> ctrl : importFromFile(filePath)
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(\n  FLIGHT_CONTROL_OPERATOR,\n  ATC_COLLABORATOR)
activate authz
authz --> ctrl
deactivate authz

note right of ctrl : Phase 1-3: DSL lexer,\nparser, semantic validation

ctrl -> runner : parse(filePath)
activate runner

note right of runner : returns structured data\nor null with errors

runner --> ctrl : dslData
deactivate runner

alt dslData == null
  ctrl --> ui : dslErrors
  deactivate ctrl
  ui --> actor : "DSL validation failed"
  deactivate ui
else dslData != null
  note right of ctrl : Phase 4: Cross-reference\nvalidation + assembly

  ctrl -> assembler : assemble(dslData)
  activate assembler

  assembler -> aptRepo : ofIdentity(depAirportIATA)
  activate aptRepo
  aptRepo --> assembler : depAirport
  deactivate aptRepo

  assembler -> aptRepo : ofIdentity(arrAirportIATA)
  activate aptRepo
  aptRepo --> assembler : arrAirport
  deactivate aptRepo

  assembler -> acRepo : ofIdentity(aircraftReg)
  activate acRepo
  acRepo --> assembler : aircraft
  deactivate acRepo

  assembler -> pilotRepo : ofIdentity(pilotId)
  activate pilotRepo
  pilotRepo --> assembler : pilot
  deactivate pilotRepo

  note right of assembler : C07: validate pilot\nis certified for\naircraft model

  assembler -> pilotRepo : pilot.certifications()
  activate pilotRepo
  pilotRepo --> assembler : Set<AircraftModelCode>
  deactivate pilotRepo

  assembler -> routeRepo : ofIdentity(routeName)
  activate routeRepo
  routeRepo --> assembler : route
  deactivate routeRepo

  create flight
  assembler -> flight ** : new Flight(\n  designator,\n  type,\n  route,\n  aircraft,\n  pilot,\n  dslContent,\n  legs)

  assembler --> ctrl : flight
  deactivate assembler

  ctrl -> fpRepo : save(flight)
  activate fpRepo
  fpRepo --> ctrl : savedFlight
  deactivate fpRepo

  ctrl --> ui : savedFlight
  deactivate ctrl

  ui --> actor : "Flight plan imported\nsuccessfully (DRAFT)"
  deactivate ui
end

@enduml
