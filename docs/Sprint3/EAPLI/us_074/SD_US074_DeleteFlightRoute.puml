@startuml sd_us074_delete_flight_route
title US074 — Delete (Deactivate) Flight Route

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "ATC Collaborator" as actor
participant ":DeleteFlightRouteUI"         as ui        <<presentation>>
participant ":DeleteFlightRouteController" as ctrl      <<application>>
participant ":AuthorizationService"        as authz     <<framework>>
participant ":FlightRouteRepository"       as routeRepo <<repository>>
participant ":FlightRepository"            as flightRepo <<repository>>
participant ":FlightRoute"                 as route     <<domain>>

== List active routes ==

actor -> ui : deactivate flight route
activate ui

ui -> ctrl : activeRoutes()
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(\n  AISafeRoles.ATC_COLLABORATOR)
activate authz
authz --> ctrl
deactivate authz

ctrl -> routeRepo : findAllActive()
activate routeRepo
routeRepo --> ctrl : Iterable<FlightRoute>
deactivate routeRepo

ctrl --> ui : Iterable<FlightRoute>
deactivate ctrl

note right of ui
  displays list of active routes;
  user selects a route and
  enters the deactivation date
end note

== Deactivate selected route ==

actor -> ui : selects route + enters deactivationDate : LocalDate

ui -> ctrl : deactivateRoute(\n  routeName : String, deactivationDate : LocalDate)
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(\n  AISafeRoles.ATC_COLLABORATOR)
activate authz
authz --> ctrl
deactivate authz

note over ctrl
  name = FlightRouteName.valueOf(routeName)
end note

ctrl -> routeRepo : ofIdentity(name : FlightRouteName)
activate routeRepo
routeRepo --> ctrl : Optional<FlightRoute>
deactivate routeRepo

ctrl -> flightRepo : existsByRouteNameAndDepartureTimeAfter(\n  name : FlightRouteName,\n  deactivationDate.atStartOfDay() : LocalDateTime)
activate flightRepo
flightRepo --> ctrl : false
deactivate flightRepo

ctrl -> route : deactivate(deactivationDate : LocalDate)
activate route
route --> ctrl
deactivate route

ctrl -> routeRepo : save(route : FlightRoute)
activate routeRepo
routeRepo --> ctrl : FlightRoute
deactivate routeRepo

ctrl --> ui : FlightRoute
deactivate ctrl

ui --> actor : "Route '<name>' deactivated successfully from <date>"
deactivate ui

@enduml
