@startuml sd_us112_monthly_report_generation
title US112 — Monthly Report Generation

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam ParticipantPadding 20

autonumber

actor "FlightControlOperator" as actor
participant ":GenerateMonthlyReportUI"        as ui        <<presentation>>
participant ":GenerateMonthlyReportController" as ctrl     <<application>>
participant ":AuthorizationService"           as authz     <<framework>>
participant ":CollaboratorRepository"         as collabRepo <<persistence>>
participant "interface\n:MonthlyReportDataProvider" as provider <<application>>
participant "impl\n:DatabaseMonthlyReportDataProvider" as providerImpl <<application>>
participant ":FlightRepository"               as flightRepo <<persistence>>
participant ":WeatherDataRepository"          as wdRepo    <<persistence>>
participant ":PilotRepository"                as pilotRepo <<persistence>>
participant ":AircraftRepository"             as acRepo    <<persistence>>
participant ":MonthlyReport"                  as report    <<domain>>

actor -> ui : selects "Generate Monthly Report"
activate ui

ui -> actor : requests month and year
actor -> ui : provides month and year

ui -> ctrl : generateForMonth(YearMonth period) : MonthlyReport
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(FLIGHT_CONTROL_OPERATOR) : void
activate authz
authz --> ctrl
deactivate authz

ctrl -> collabRepo : findBySystemUser(SystemUser) : Optional<Collaborator>
activate collabRepo
collabRepo --> ctrl : collaborator
deactivate collabRepo

ctrl -> ctrl : areaCodeOfCurrentUser() : AreaCode
ctrl -> provider : generateForMonth(YearMonth period, AreaCode areaCode) : MonthlyReport
activate providerImpl

providerImpl -> flightRepo : findAll() : Iterable<Flight>
activate flightRepo
flightRepo --> providerImpl : all flights
deactivate flightRepo

loop for each flight in period
    providerImpl -> providerImpl : count flight, flightsPerWeek
    loop for each flightPlan
        providerImpl -> providerImpl : classify status\n(DRAFT/IN_TEST/TEST_PASSED/TEST_FAILED)
    end
end

providerImpl -> wdRepo : findByAreaCode(AreaCode) : Iterable<WeatherData>
activate wdRepo
wdRepo --> providerImpl : weather data for area
deactivate wdRepo

providerImpl -> pilotRepo : findAll() : Iterable<Pilot>
activate pilotRepo
pilotRepo --> providerImpl : all pilots
deactivate pilotRepo

providerImpl -> acRepo : findAll() : Iterable<Aircraft>
activate acRepo
acRepo --> providerImpl : all aircraft
deactivate acRepo

create report
providerImpl -> report : MonthlyReport(\n  YearMonth period,\n  long totalFlights,\n  long totalFlightPlans,\n  long flightPlansDraft,\n  long flightPlansInTest,\n  long flightPlansPassed,\n  long flightPlansFailed,\n  long totalWeatherRecords,\n  long totalActivePilots,\n  long totalAircraft,\n  String flightsPerWeek\n)
activate report
report --> providerImpl
deactivate report

providerImpl --> ctrl : MonthlyReport
deactivate providerImpl

ctrl --> ui : MonthlyReport
deactivate ctrl

ui -> ui : prints report to console
ui -> ui : saves report to\nreports/monthly-report-YYYY-MM.txt

ui --> actor : displays confirmation and file path
deactivate ui

@enduml