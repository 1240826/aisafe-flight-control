@startuml sd_us042_import_weather_data
title US042 — Import Bulk Weather Data

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam ParticipantPadding 20

autonumber

actor "WeatherPerson" as actor
participant ":ImportBulkWeatherDataUI"    as ui       <<presentation>>
participant ":ImportBulkWeatherDataController" as ctrl <<application>>
participant ":AuthorizationService"       as authz    <<framework>>
participant ":AirControlAreaRepository"   as acaRepo  <<persistence>>
participant ":WeatherDataRepository"      as repo     <<persistence>>

actor -> ui : selects "Import Bulk Weather Data"
activate ui

ui -> actor : requests file path
actor -> ui : provides file path

ui -> ctrl : importFromCsv(Path csvPath) : ImportResult
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(WEATHER_PERSON) : void
activate authz
authz --> ctrl
deactivate authz

loop for each line in CSV
    alt line starts with '#'
        ctrl -> ctrl : parseHeader(String line, Map<String,AreaCode>) : void
        activate ctrl
        ctrl -> acaRepo : ofIdentity(AreaCode.valueOf(areaCodeStr)) : Optional<AirControlArea>
        activate acaRepo
        acaRepo --> ctrl : AirControlArea (or throws)
        deactivate acaRepo
        deactivate ctrl
    else data line
        ctrl -> ctrl : parseLine(String line, int lineNum, Map<String,AreaCode>) : WeatherData
        
        ctrl -> repo : save(WeatherData) : void
        activate repo
        repo --> ctrl
        deactivate repo
        
        ctrl -> ctrl : imported++
    end
    note right : on error: skipped++,\nerror added to list
end

ctrl --> ui : ImportResult(imported:int, skipped:int, errors:List<String>)
deactivate ctrl

ui --> actor : displays import summary
deactivate ui

@enduml