@startuml sd_us042_import_weather_data
title US042 — Import Bulk Weather Data

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "WeatherPerson" as actor
participant ":ImportBulkWeatherDataUI"    as ui       <<presentation>>
participant ":ImportBulkWeatherDataController" as ctrl <<application>>
participant ":AuthorizationService"       as authz    <<framework>>
participant ":AirControlAreaRepository"   as acaRepo  <<persistence>>
participant ":WeatherDataRepository"      as repo     <<persistence>>

actor -> ui : selects "Import Weather Data"
activate ui

ui -> actor : requests file path
actor -> ui : provides file path

ui -> ctrl : importFromCsv(csvPath)
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(WEATHER_PERSON)
activate authz
authz --> ctrl
deactivate authz

loop for each line in CSV
    alt line starts with '#'
        ctrl -> ctrl : parseHeader(line) – extracts ACA mapping
        activate ctrl
        ctrl -> acaRepo : ofIdentity(areaCode)
        activate acaRepo
        acaRepo --> ctrl : aca (or throws if unknown)
        deactivate acaRepo
        deactivate ctrl
    else data line
        ctrl -> ctrl : parseLine(line, acaMapping) – 12 columns, European decimals
        
        ctrl -> repo : save(weatherData)
        activate repo
        repo --> ctrl
        deactivate repo
        
        ctrl -> ctrl : imported++
    end
    note right : on error: skipped++,\nerror added to list
end

ctrl --> ui : ImportResult(imported, skipped, errors)
deactivate ctrl

ui --> actor : displays import summary
deactivate ui

@enduml
