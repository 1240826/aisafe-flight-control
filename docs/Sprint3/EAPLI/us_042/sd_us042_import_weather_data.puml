@startuml sd_us042_import_weather_data
title US042 — Import Bulk Weather Data

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "WeatherPerson" as actor
participant ":ImportWeatherDataUI"         as ui       <<presentation>>
participant ":ImportWeatherDataController" as ctrl     <<application>>
participant ":AuthorizationService"        as authz    <<framework>>
participant ":WeatherDataImporterFactory"  as factory  <<application>>
participant ":CSVWeatherDataImporter"      as importer <<application>>
participant ":WeatherDataRepository"       as repo     <<persistence>>

actor -> ui : selects "Import Weather Data"
activate ui

ui -> actor : requests file path
actor -> ui : provides file path

ui -> ctrl : importWeatherData(filePath)
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(WEATHER_PERSON)
activate authz
authz --> ctrl
deactivate authz

ctrl -> factory : getImporter(filePath)
activate factory
factory --> ctrl : importer
deactivate factory

ctrl -> importer : parse(filePath)
activate importer
importer --> ctrl : weatherDataList, errorList
deactivate importer

loop for each valid WeatherData
    ctrl -> repo : save(weatherData)
    activate repo
    repo --> ctrl
    deactivate repo
end

ctrl --> ui : importSummary(imported, errors)
deactivate ctrl

ui --> actor : displays import summary
deactivate ui

@enduml