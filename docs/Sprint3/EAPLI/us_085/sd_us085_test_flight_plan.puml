@startuml sd_us085_test_flight_plan
title US085 — Test/Validate Flight Plan (Happy Path)

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "Flight Control Operator" as actor
participant ":TestFlightPlanUI"                as ui          <<presentation>>
participant ":TestFlightPlanController"        as ctrl        <<application>>
participant "flight:Flight"                    as flight      <<domain>>
participant "plan:FlightPlan"                  as plan        <<domain>>
participant ":DslValidator"                    as dsl         <<service>>
participant ":FlightPlanExporter"              as exporter    <<service>>
participant ":ProcessBuilderSimulationRunner"  as runner      <<service>>
participant "ReportParser"                     as parser      <<service>>
participant ":FlightRepository"                as repo        <<persistence>>

actor -> ui : selects flight + flight plan
activate ui
ui -> ctrl : testFlightPlan("TP1234", "FP001")
activate ctrl

note right of ctrl : Phase 0 — Authorization
ctrl -> ctrl : ensureAuthenticatedUserHasAnyOf(FLIGHT_CONTROL_OPERATOR)

note right of ctrl : Phase 1 — Load Flight + FlightPlan
ctrl -> repo : ofIdentity(FlightDesignator.valueOf("TP1234"))
activate repo
repo --> ctrl : Flight("TP1234")
deactivate repo
ctrl -> flight : flightPlan(FlightPlanId.valueOf("FP001"))
activate flight
flight --> ctrl : FlightPlan("FP001")
deactivate flight

note right of ctrl : Phase 2 — Check DRAFT status
ctrl -> plan : status()
activate plan
plan --> ctrl : DRAFT
deactivate plan

note right of ctrl : Phase 3 — DSL Re-validation
ctrl -> plan : dslContent()
activate plan
plan --> ctrl : raw DSL string
deactivate plan
ctrl -> dsl : validate(dslContent)
activate dsl
dsl --> ctrl : ValidationResult(passed)
deactivate dsl

ctrl -> plan : markAsInTest()
activate plan
plan --> ctrl : status = IN_TEST
deactivate plan
ctrl -> repo : save(flight)
activate repo
repo --> ctrl : ok
deactivate repo

note right of ctrl : Phase 4 — JSON Export
ctrl -> exporter : exportForSimulator(flightPlan)
activate exporter
exporter --> ctrl : jsonPayload
deactivate exporter

note right of ctrl : Phase 5 — C Simulation
ctrl -> runner : run(jsonPayload)
activate runner
runner --> ctrl : reportContent (String)
deactivate runner

note right of ctrl : Phase 6 — Parse Report
ctrl -> parser : parse(reportContent)
activate parser
parser --> ctrl : ReportParseResult(passed=yes, viol=0)
deactivate parser

note right of ctrl : Phase 7 — Record Result
ctrl -> plan : recordTestResult(true, null, reportContent)
activate plan
plan --> ctrl : status = TEST_PASSED
deactivate plan

ctrl -> repo : save(flight)
activate repo
repo --> ctrl : ok
deactivate repo

ctrl --> ui : TestResult(passed, "PASSED (violations: 0)", reportContent)
deactivate ctrl
ui --> actor : "Flight plan FP001 PASSED (violations: 0)"
deactivate ui
@enduml
