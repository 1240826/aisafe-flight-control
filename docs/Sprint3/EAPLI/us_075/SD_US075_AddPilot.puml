@startuml sd_us075_add_pilot
title US075 — Add a Pilot

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "ATCC" as actor
participant ":AddPilotUI" as ui <<presentation>>
participant ":AddPilotController" as ctrl <<application>>
participant ":AuthorizationService" as authz <<framework>>
participant ":UserManagementService" as userSvc <<framework>>
participant ":AircraftModelRepository" as modelRepo <<repository>>
participant ":PilotRepository" as pilotRepo <<repository>>
participant "p:Pilot" as pilot <<domain>>

actor -> ui : add pilot
activate ui

ui -> ctrl : getAircraftModels()
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(\n  ATC_COLLABORATOR)
activate authz
authz --> ctrl
deactivate authz

ctrl -> modelRepo : findAll()
activate modelRepo
modelRepo --> ctrl : aircraftModels
deactivate modelRepo

ctrl --> ui : aircraftModels
deactivate ctrl

note right of ui : username entered as string\ncertifiedModels selected\nfrom available aircraft models

ui -> ctrl : addPilot(\n  username,\n  certifiedModelIds)
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(\n  ATC_COLLABORATOR)
activate authz
authz --> ctrl
deactivate authz

ctrl -> authz : loggedinUserWithPermission(\n  ATC_COLLABORATOR)
activate authz
authz --> ctrl : atccUser
deactivate authz

ctrl -> userSvc : findUserByUsername(username)
activate userSvc
userSvc --> ctrl : systemUser
deactivate userSvc

note right of ctrl : throws exception if\nuser not found

ctrl -> pilotRepo : findByUserAndCompany(\n  systemUser, atccUser.company())
activate pilotRepo
pilotRepo --> ctrl : optional<Pilot>
deactivate pilotRepo

note right of ctrl : throws exception if\npilot already active\nin this company

ctrl -> modelRepo : findAllById(certifiedModelIds)
activate modelRepo
modelRepo --> ctrl : certifiedModels
deactivate modelRepo

note right of ctrl : throws exception if any\nmodel ID does not exist

create pilot
ctrl -> pilot ** : new Pilot(\n  systemUser,\n  atccUser.company(),\n  certifiedModels)

ctrl -> pilotRepo : save(pilot)
activate pilotRepo
pilotRepo --> ctrl : savedPilot
deactivate pilotRepo

ctrl --> ui : savedPilot
deactivate ctrl

ui --> actor : "Pilot added successfully"
deactivate ui

@enduml
