@startuml sd_us075_add_pilot
title US075 — Add a Pilot

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "ATCC" as actor
participant ":AddPilotUI" as ui <<presentation>>
participant ":AddPilotController" as ctrl <<application>>
participant ":AuthorizationService" as authz <<framework>>
participant ":AirTransportCompanyRepository" as companyRepo <<repository>>
participant ":AircraftModelRepository" as modelRepo <<repository>>
participant ":PilotRepository" as pilotRepo <<repository>>
participant "pilotId:PilotId" as pilotId <<domain>>
participant "p:Pilot" as pilot <<domain>>

actor -> ui : add pilot
activate ui

ui -> ctrl : allCompanies()
activate ctrl
ctrl -> companyRepo : findAll()
activate companyRepo
companyRepo --> ctrl : companies
deactivate companyRepo
ctrl --> ui : companies
deactivate ctrl

note right of ui : user selects one company\nfrom the numbered list

ui -> ctrl : allAircraftModels()
activate ctrl
ctrl -> modelRepo : findAll()
activate modelRepo
modelRepo --> ctrl : aircraftModels
deactivate modelRepo
ctrl --> ui : aircraftModels
deactivate ctrl

note right of ui : licenseNumber entered as string\ncertifiedModels toggled from list\ncertificationDate entered (YYYY-MM-DD)

ui -> ctrl : addPilot(\n  licenseNumber,\n  company,\n  certifiedModels,\n  certificationDate)
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(\n  ATC_COLLABORATOR)
activate authz
authz --> ctrl
deactivate authz

create pilotId
ctrl -> pilotId ** : valueOf(licenseNumber)

note right of ctrl : throws if format invalid\n(must match [A-Z][0-9]{4,10})

create pilot
ctrl -> pilot ** : new Pilot(\n  pilotId,\n  company,\n  certifiedModels,\n  certificationDate)

note right of ctrl : throws if certifiedModels empty\nor certificationDate in the future

ctrl -> pilotRepo : save(pilot)
activate pilotRepo
pilotRepo --> ctrl : savedPilot
deactivate pilotRepo

ctrl --> ui : savedPilot
deactivate ctrl

ui --> actor : "Pilot added successfully"
deactivate ui

@enduml
