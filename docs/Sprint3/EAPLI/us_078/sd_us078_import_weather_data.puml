@startuml sd_us078_atcc_remote_access
title US078 — ATCC Remote Access

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "ATC Collaborator" as actor
participant "ATCClientApp"          as client  <<client>>
participant "ATCServerDaemon"       as server  <<server>>
participant "ATCClientHandler"      as handler <<thread>>
participant ":System Controllers"   as ctrl    <<application>>

actor -> client : runs application
activate client

client -> server : establish TCP connection (IP:Port)
activate server
server -> handler** : spawn thread for client
deactivate server

client -> handler : send(AuthRequestMessage)
activate handler
handler -> handler : authenticateUser()
handler --> client : send(AuthResponseMessage)
deactivate handler

actor -> client : triggers domain action (e.g., Create Route)
client -> handler : send(CreateRouteRequestMessage)
activate handler

handler -> ctrl : createRoute(...)
activate ctrl
ctrl --> handler : success
deactivate ctrl

handler --> client : send(CreateRouteResponseMessage)
deactivate handler

client --> actor : displays success message
deactivate client
@enduml