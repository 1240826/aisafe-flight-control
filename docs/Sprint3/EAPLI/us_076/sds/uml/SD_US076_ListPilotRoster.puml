@startuml sd_us076_list_pilot_roster
title US076 — List Pilot Roster

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "ATCC" as actor
participant ":ListPilotRosterUI" as ui <<presentation>>
participant ":ListPilotRosterController" as ctrl <<application>>
participant ":AuthorizationService" as authz <<framework>>
participant ":AirTransportCompanyRepository" as companyRepo <<repository>>
participant ":PilotRepository" as pilotRepo <<repository>>

actor -> ui : list pilot roster
activate ui

ui -> ctrl : allCompanies()
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(\n  ATC_COLLABORATOR)
activate authz
authz --> ctrl
deactivate authz

ctrl -> companyRepo : findAll()
activate companyRepo
companyRepo --> ctrl : companies
deactivate companyRepo

ctrl --> ui : companies
deactivate ctrl

note right of ui : user selects one company\nfrom the numbered list

ui -> ctrl : listCompanyPilots(company)
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(\n  ATC_COLLABORATOR)
activate authz
authz --> ctrl
deactivate authz

ctrl -> pilotRepo : findByCompany(company)
activate pilotRepo
pilotRepo --> ctrl : pilots
deactivate pilotRepo

ctrl --> ui : pilots
deactivate ctrl

note right of ui : displays tabular list with\nlicense number, company, status\n(ACTIVE / INACTIVE) and\ncertified aircraft models;\nshows empty message if list is empty

ui --> actor : pilot roster
deactivate ui

@enduml
