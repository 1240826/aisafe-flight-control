@startuml sd_us111_generate_simulation_report
title US111 — Generate a Simulation Report

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "Flight Control Operator" as actor
participant ":GenerateSimulationReportUI"        as ui       <<presentation>>
participant ":GenerateSimulationReportController" as ctrl    <<application>>
participant ":AuthorizationService"              as authz    <<framework>>
participant ":SimulationRepository"              as simRepo  <<persistence>>
participant ":SimulationReportFileWriter"        as writer   <<application>>

actor -> ui : selects "Generate Simulation Report"
activate ui

ui -> ctrl : allSimulations()
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(\n  ADMIN, FLIGHT_CONTROL_OPERATOR)
activate authz
authz --> ctrl
deactivate authz

ctrl -> simRepo : findAll()
activate simRepo
simRepo --> ctrl : simulations
deactivate simRepo

ctrl --> ui : simulations
deactivate ctrl

ui -> actor : displays list of simulations
actor -> ui : selects simulation

ui -> ctrl : generateReport(areaCode)
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(\n  ADMIN, FLIGHT_CONTROL_OPERATOR)
activate authz
authz --> ctrl
deactivate authz

ctrl -> simRepo : findByAreaCode(areaCode)
activate simRepo
simRepo --> ctrl : simulation
deactivate simRepo

note right of ctrl
  outputPath =
  "reports/simulation_report_" + areaCode + ".txt"
  writer reads simulation.report().content()
end note

ctrl -> writer : writeToFile(simulation, outputPath)
activate writer
writer --> ctrl : filePath
deactivate writer

ctrl --> ui : filePath
deactivate ctrl

ui --> actor : "Report generated successfully: <filePath>"
deactivate ui

@enduml
