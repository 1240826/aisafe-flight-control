@startuml sd_us077_remove_pilot
title US077 — Remove a Pilot

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "ATCC" as actor
participant ":RemovePilotUI" as ui <<presentation>>
participant ":RemovePilotController" as ctrl <<application>>
participant ":AuthorizationService" as authz <<framework>>
participant ":PilotRepository" as pilotRepo <<repository>>
participant ":FlightRepository" as flightRepo <<repository>>
participant "p:Pilot" as pilot <<domain>>

actor -> ui : remove pilot
activate ui

ui -> ctrl : allPilots()
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(\n  ATC_COLLABORATOR)
activate authz
authz --> ctrl
deactivate authz

ctrl -> pilotRepo : findAll()
activate pilotRepo
pilotRepo --> ctrl : pilots
deactivate pilotRepo

ctrl --> ui : pilots
deactivate ctrl

note right of ui : ATCC selects pilot\nfrom the full list\n(active and inactive)\nand confirms deactivation

ui -> ctrl : deactivatePilot(pilotId)
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(\n  ATC_COLLABORATOR)
activate authz
authz --> ctrl
deactivate authz

ctrl -> pilotRepo : findByLicenseNumber(pilotId)
activate pilotRepo
pilotRepo --> ctrl : optional<Pilot>
deactivate pilotRepo

note right of ctrl : throws IllegalArgumentException\nif pilot not found

ctrl -> flightRepo : existsByPilotLicense(pilotId)
activate flightRepo
flightRepo --> ctrl : hasAssignedFlights
deactivate flightRepo

note right of ctrl : throws IllegalStateException\nif pilot has flight plans assigned

ctrl -> pilot : deactivate()
activate pilot
note right of pilot : sets active = false;\nthrows if already inactive
pilot --> ctrl
deactivate pilot

ctrl -> pilotRepo : save(pilot)
activate pilotRepo
pilotRepo --> ctrl : savedPilot
deactivate pilotRepo

ctrl --> ui : savedPilot
deactivate ctrl

ui --> actor : "Pilot removed successfully"
deactivate ui

@enduml
