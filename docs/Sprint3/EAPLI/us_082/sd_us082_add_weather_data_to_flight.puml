@startuml sd_us082_add_weather_data_to_flight
title US082 — Insert Weather Data in a Flight

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "Pilot" as actor
participant ":AddWeatherToFlightUI"        as ui      <<presentation>>
participant ":AddWeatherToFlightController" as ctrl   <<application>>
participant ":AuthorizationService"        as authz   <<framework>>
participant ":FlightRepository"            as flightRepo <<persistence>>
participant ":AirControlAreaRepository"    as acaRepo <<persistence>>
participant ":WeatherDataRepository"       as wdRepo  <<persistence>>
participant ":Flight"                      as flight  <<domain>>

actor -> ui : selects "Add Weather Data to Flight"
activate ui

ui -> ctrl : allFlights()
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(PILOT)
activate authz
authz --> ctrl
deactivate authz

ctrl -> flightRepo : findAll()
activate flightRepo
flightRepo --> ctrl : flights
deactivate flightRepo

ctrl --> ui : flights (client-side filtered by matching designator)
deactivate ctrl

ui -> actor : displays flight list
actor -> ui : selects flight

ui -> ctrl : weatherDataForFlight(flight)
activate ctrl

ctrl -> ctrl : computeMidpoint(flight) – midpoint lat/lon from route
ctrl -> acaRepo : findAll()
activate acaRepo
acaRepo --> ctrl : all ACAs
deactivate acaRepo

ctrl -> ctrl : findAcaForMidpoint(lat, lon) – finds ACA containing midpoint

ctrl -> wdRepo : findAll()
activate wdRepo
wdRepo --> ctrl : all weather data
deactivate wdRepo

ctrl -> ctrl : filters weather data by matched ACA code
ctrl --> ui : weatherList (ACA-filtered)
deactivate ctrl

ui -> actor : displays weather data list
actor -> ui : selects weather data

ui -> ctrl : assignWeather(flightDesignator, weatherDataId)
activate ctrl

ctrl -> wdRepo : ofIdentity(weatherDataId)
activate wdRepo
wdRepo --> ctrl : weatherData (or throws)
deactivate wdRepo

ctrl -> flightRepo : ofIdentity(flightDesignator)
activate flightRepo
flightRepo --> ctrl : flight
deactivate flightRepo

ctrl -> flight : assignWeatherData(weatherDataId)
activate flight
flight --> ctrl
deactivate flight

ctrl -> flightRepo : save(flight)
activate flightRepo
flightRepo --> ctrl
deactivate flightRepo

ctrl --> ui : updated flight
deactivate ctrl

ui --> actor : displays confirmation
deactivate ui

@enduml
