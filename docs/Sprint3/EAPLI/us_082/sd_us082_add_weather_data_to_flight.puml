@startuml sd_us082_add_weather_data_to_flight
title US082 — Insert Weather Data in a Flight

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam ParticipantPadding 20

autonumber

actor "Pilot" as actor
participant ":AddWeatherToFlightUI"        as ui      <<presentation>>
participant ":AddWeatherToFlightController" as ctrl   <<application>>
participant ":AuthorizationService"        as authz   <<framework>>
participant ":FlightRepository"            as flightRepo <<persistence>>
participant ":AirControlAreaRepository"    as acaRepo <<persistence>>
participant ":WeatherDataRepository"       as wdRepo  <<persistence>>
participant ":Flight"                      as flight  <<domain>>

actor -> ui : selects "Add Weather Data to Flight"
activate ui

ui -> ctrl : allFlights() : Iterable<Flight>
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(PILOT) : void
activate authz
authz --> ctrl
deactivate authz

ctrl -> flightRepo : findAll() : Iterable<Flight>
activate flightRepo
flightRepo --> ctrl : flights
deactivate flightRepo

ctrl --> ui : flights (client-side filtered by matching designator)
deactivate ctrl

ui -> actor : displays flight list
actor -> ui : selects flight

ui -> ctrl : weatherDataForFlight(Flight) : List<WeatherData>
activate ctrl

ctrl -> ctrl : computeMidpoint(Flight) : RouteMidpoint
ctrl -> acaRepo : findAll() : Iterable<AirControlArea>
activate acaRepo
acaRepo --> ctrl : all ACAs
deactivate acaRepo

ctrl -> ctrl : findAcaForMidpoint(double lat, double lon) : AirControlArea

ctrl -> wdRepo : findAll() : Iterable<WeatherData>
activate wdRepo
wdRepo --> ctrl : all weather data
deactivate wdRepo

ctrl -> ctrl : filters weather data by matched ACA code
ctrl --> ui : weatherList (ACA-filtered)
deactivate ctrl

ui -> actor : displays weather data list
actor -> ui : selects weather data

ui -> ctrl : assignWeather(String flightDesignator, Long weatherDataId) : Flight
activate ctrl

ctrl -> wdRepo : ofIdentity(Long weatherDataId) : Optional<WeatherData>
activate wdRepo
wdRepo --> ctrl : weatherData (or throws)
deactivate wdRepo

ctrl -> flightRepo : ofIdentity(FlightDesignator) : Optional<Flight>
activate flightRepo
flightRepo --> ctrl : flight
deactivate flightRepo

ctrl -> flight : assignWeatherData(Long weatherDataId) : void
activate flight
flight --> ctrl
deactivate flight

ctrl -> flightRepo : save(Flight) : Flight
activate flightRepo
flightRepo --> ctrl : saved flight
deactivate flightRepo

ctrl --> ui : updated flight
deactivate ctrl

ui --> actor : displays confirmation
deactivate ui

@enduml