@startuml sd_us044_weather_remote_access
title US44 — Weather Person Remote Access

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "Weather Person" as actor
participant ":WeatherClientApp" as client <<client>>
participant ":TcpWeatherServer" as server <<server>>
participant ":WeatherClientHandler" as handler <<server>>
participant ":RemoteWeatherService" as service <<application>>
participant ":UdpLoggerService" as logger <<server>>

actor -> client : launch app
activate client

client -> server : TCP connect
activate server

server -> handler ** : new WeatherClientHandler(socket)
activate handler

client -> handler : AUTH|<username>|<password>
handler -> service : authenticate(username, password)
activate service
service --> handler : result
deactivate service

alt authentication successful
    handler -> logger : log(AUTH_OK, username, ip, port, US44)
    activate logger
    logger --> handler
    deactivate logger
    handler --> client : AUTH_OK
else authentication failed
    handler -> logger : log(AUTH_FAIL, username, ip, port, US44)
    activate logger
    logger --> handler
    deactivate logger
    handler --> client : AUTH_FAIL|<reason>
end

note right of client : authenticated session;\nclient sends operation requests

client -> handler : <OPERATION>|<params>
handler -> service : executeOperation(params)
activate service
service --> handler : result
deactivate service
handler --> client : OK|<data> or ERR|<reason>

client -> handler : QUIT
handler -> logger : log(LOGOUT, username, ip, port, US44)
activate logger
logger --> handler
deactivate logger
handler --> client : OK
deactivate handler

client -> server : TCP disconnect
deactivate server
deactivate client

@enduml
