@startuml sd_us90_login_event
title US90 — Remote Access Logging (Login Event)

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "Remote User\n(US44 / US78 / US86)" as client
participant ":TcpClientHandler"     as handler <<handler>>
participant ":AuthorizationService" as authz   <<framework>>
participant ":UdpLoggerService"     as logger  <<service>>
participant "Logging Server\n(UDP)" as server  <<external>>

client -> handler : connect + send credentials
activate handler

handler -> authz : authenticateUser(username, password)
activate authz
authz --> handler : result (success / failure)
deactivate authz

handler -> logger : sendLog(timestamp, username,\n  clientIp, clientPort,\n  serviceId, eventType)
activate logger

note right of logger
  payload format:
  timestamp|username|clientIp|
  clientPort|serviceId|eventType
end note

logger -> server : UDP datagram (logEntry)
activate server
note right of server
  fire-and-forget —
  no acknowledgement expected;
  send failures caught and ignored
end note
server --> logger
deactivate server

logger --> handler
deactivate logger

alt LOGIN_SUCCESS
    handler --> client : access granted
else LOGIN_FAILURE
    handler --> client : access denied
end

deactivate handler

@enduml


@startuml sd_us90_logout_disconnect_event
title US90 — Remote Access Logging (Logout / Disconnect Event)

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "Remote User\n(US44 / US78 / US86)" as client
participant ":TcpClientHandler"     as handler <<handler>>
participant ":UdpLoggerService"     as logger  <<service>>
participant "Logging Server\n(UDP)" as server  <<external>>

alt Logout
    client -> handler : logout / exit request
else Disconnect
    client ->x handler : connection drop\n(IOException on read)
end

activate handler

handler -> logger : sendLog(timestamp, username,\n  clientIp, clientPort,\n  serviceId, LOGOUT / DISCONNECT)
activate logger

note right of logger
  payload format:
  timestamp|username|clientIp|
  clientPort|serviceId|eventType
end note

logger -> server : UDP datagram (logEntry)
activate server
note right of server
  fire-and-forget —
  no acknowledgement expected;
  send failures caught and ignored
end note
server --> logger
deactivate server

logger --> handler
deactivate logger

deactivate handler

@enduml
