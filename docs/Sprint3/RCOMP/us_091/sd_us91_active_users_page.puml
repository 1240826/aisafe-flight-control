@startuml sd_us91_active_users_page
title US91 — Active Users Page (Initial Load + AJAX Polling)

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "Administrator\n(Browser)" as admin
participant ":HttpVisualizationServer"  as http  <<server>>
participant ":ActiveUsersPageHandler"   as page  <<handler>>
participant ":ActiveUsersApiHandler"    as api   <<handler>>
participant ":RemoteAccessEventStore"   as store <<domain>>

admin -> http : GET /active
activate http
http -> page : handle(request)
activate page
page --> http : HTML page (with AJAX script)
deactivate page
http --> admin : 200 OK — HTML
deactivate http

note over admin : Browser renders page\nand executes AJAX script

loop every 5 seconds (and immediately on page load)
    admin -> http : GET /api/active
    activate http
    http -> api : handle(request)
    activate api
    api -> store : getEvents()
    activate store
    store --> api : eventList
    deactivate store
    note over api : Derive active users:\nfor each session (username + ip + port)\nlast event must be LOGIN_SUCCESS\nwith no subsequent LOGOUT or DISCONNECT
    api --> http : JSON response (activeUserList)
    deactivate api
    http --> admin : 200 OK — JSON
    deactivate http
    note over admin : Replace table body\nUpdate last-updated timestamp
end

@enduml