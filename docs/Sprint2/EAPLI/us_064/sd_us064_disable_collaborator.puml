@startuml sd_us064_disable_collaborator
title US064 — Disable Collaborator

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "Admin" as actor
participant ":DisableCollaboratorUI" as ui <<presentation>>
participant ":DisableCollaboratorController" as ctrl <<application>>
participant ":AuthorizationService" as authz <<framework>>
participant ":CollaboratorRepository" as repo <<repository>>
participant "c:Collaborator" as collab <<domain>>

actor -> ui : disable collaborator
activate ui

ui -> ctrl : activeCollaborators()
activate ctrl
ctrl -> authz : ensureAuthenticatedUserHasAnyOf(\n  ADMIN, BACKOFFICE_OPERATOR)
activate authz
authz --> ctrl
deactivate authz
ctrl -> repo : findAllActive()
activate repo
repo --> ctrl : activeCollaborators
deactivate repo
ctrl --> ui : activeCollaborators
deactivate ctrl

ui --> actor : displays active collaborators for selection

actor -> ui : selects collaborator to disable
activate ui

ui -> ctrl : disableCollaborator(collaboratorId)
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(\n  ADMIN, BACKOFFICE_OPERATOR)
activate authz
authz --> ctrl
deactivate authz

ctrl -> repo : ofIdentity(collaboratorId)
activate repo
repo --> ctrl : collab
deactivate repo

ctrl -> collab : disable()
activate collab
note right : sets status to INACTIVE\nirreversible operation
collab --> ctrl
deactivate collab

ctrl -> repo : save(collab)
activate repo
repo --> ctrl : savedCollab
deactivate repo

ctrl --> ui : savedCollab
deactivate ctrl

ui --> actor : "Collaborator disabled"
deactivate ui

@enduml
