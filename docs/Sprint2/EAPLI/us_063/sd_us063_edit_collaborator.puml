@startuml sd_us063_edit_collaborator
title US063 — Edit Collaborator

skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ParticipantPadding 20

autonumber

actor "Backoffice Operator" as actor
participant ":EditCollaboratorUI" as ui <<presentation>>
participant ":EditCollaboratorController" as ctrl <<application>>
participant ":AuthorizationService" as authz <<framework>>
participant ":CollaboratorRepository" as repo <<repository>>
participant "c:Collaborator" as collab <<domain>>

actor -> ui : edit collaborator
activate ui

ui -> ctrl : activeCollaborators()
activate ctrl
ctrl -> authz : ensureAuthenticatedUserHasAnyOf(\n  BACKOFFICE_OPERATOR)
activate authz
authz --> ctrl
deactivate authz
ctrl -> repo : findAllActive()
activate repo
repo --> ctrl : activeCollaborators
deactivate repo
ctrl --> ui : activeCollaborators
deactivate ctrl

ui --> actor : displays active collaborators for selection

actor -> ui : selects collaborator + enters new values\n(blank = keep current; phone blank = clear)
activate ui

ui -> ctrl : editCollaborator(\n  collaboratorId,\n  newName, newPosition,\n  newPhone,\n  newClearanceExpiry,\n  newAssessmentDate)
activate ctrl

ctrl -> authz : ensureAuthenticatedUserHasAnyOf(\n  BACKOFFICE_OPERATOR)
activate authz
authz --> ctrl
deactivate authz

ctrl -> repo : ofIdentity(collaboratorId)
activate repo
repo --> ctrl : collab
deactivate repo

opt newName not null/blank
  ctrl -> collab : updateName(newName)
  activate collab
  collab --> ctrl
  deactivate collab
end

opt newPosition not null/blank
  ctrl -> collab : updatePosition(newPosition)
  activate collab
  collab --> ctrl
  deactivate collab
end

ctrl -> collab : updatePhone(newPhone)
activate collab
note right : null or blank clears the phone field
collab --> ctrl
deactivate collab

opt newClearanceExpiry not null
  ctrl -> collab : renewSecurityClearance(\n  new SecurityClearance(newClearanceExpiry))
  activate collab
  collab --> ctrl
  deactivate collab
end

opt newAssessmentDate not null
  ctrl -> collab : updateSkillsAssessment(\n  new SkillsAssessment(newAssessmentDate))
  activate collab
  collab --> ctrl
  deactivate collab
end

ctrl -> repo : save(collab)
activate repo
repo --> ctrl : savedCollab
deactivate repo

ctrl --> ui : savedCollab
deactivate ctrl

ui --> actor : "Collaborator updated"
deactivate ui

@enduml
