@startuml sd_pilot
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
title Deactivate Pilot\nInvariant: cannot deactivate pilot with assigned flights (US077)

participant ":DeactivatePilotController" as CTRL
participant "pilotRepository\n:PilotRepository" as REPO
participant "flightRepository\n:FlightRepository" as FREPO
participant "pilot\n:Pilot" as PIL

-> CTRL : deactivatePilot(pilotID)
activate CTRL

CTRL -> FREPO : hasAssignedFlights(pilotID)
activate FREPO
FREPO --> CTRL : false
deactivate FREPO

CTRL -> REPO : findByID(pilotID)
activate REPO
REPO --> CTRL : pilot
deactivate REPO

CTRL -> PIL : deactivate()
activate PIL
PIL -> PIL : ensureNoAssignedFlights()
PIL --> CTRL :
deactivate PIL

CTRL -> REPO : save(pilot)
activate REPO
REPO --> CTRL :
deactivate REPO

deactivate CTRL
@enduml
