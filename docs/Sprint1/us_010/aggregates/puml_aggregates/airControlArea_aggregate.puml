@startuml airControlArea_Aggregate
left to right direction
skinparam packageStyle rectangle
skinparam nodesep 40
skinparam ranksep 60
hide empty members


package "AirControlArea_Aggregate" <<aggregate>> {
  class AirControlArea <<entity>> <<root>> {
    maxAltitudeMetres : int
  }
  class AreaCode <<value object>> {
    code : String
  }
  note right of AreaCode : unique in system (US050)
  class AreaName <<value object>> {
    name : String
  }
  note right of AreaName : unique (client clarification)
  class BoundingBox <<value object>> {
    minLat : double
    maxLat : double
    minLon : double
    maxLon : double
  }
  note right of BoundingBox : Rectangle boundary.\nClient: "for sake of simplicity,\na rectangle".\nInvariant: minLat < maxLat, minLon < maxLon

  AirControlArea *---- AreaCode : identifiedBy
  AirControlArea *---- AreaName : namedAs
  AirControlArea *---- BoundingBox : boundedBy
}

package "Airport_Aggregate" <<aggregate>> {
  class Airport <<entity>> <<root>> {
    name : String
    city : String
    country : String
  }
  class AirportIATA <<value object>> {
    iataCode : String
  }
  class AirportICAO <<value object>> {
    icaoCode : String
  }
  class Coordinates <<value object>> {
    latitude : double
    longitude : double
  }
  note right of Coordinates : Shared VO — used by Airport\nand Simulation.\nlat ∈ [-90,90], lon ∈ [-180,180]
  class Elevation <<value object>> {
    value : double
    unit : String
  }
  note right of Elevation : metres above sea level.\nvalue > 0 (US052.6)
  Airport *-- AirportIATA : identifiedBy
  Airport *-- AirportICAO : identifiedBy
  Airport *-- Coordinates : locatedAt
  Airport *-- Elevation : situatedAt
}


package "Collaborator_Aggregate" <<aggregate>> {
  abstract class Collaborator <<entity>> <<root>> {
    name : String
    position : String
  }

  class ATCCollaborator <<entity>> {
  }
  class FlightControlOperator <<entity>> {
  }
  class WeatherPerson <<entity>> {
  }
  class SecurityClearance <<value object>> {
    expiryDate : LocalDate
  }
  note right of SecurityClearance : auto-expires.\nUpdatable by Admin/Backoffice (sec. 3.1.1)
  class SkillsAssessment <<value object>> {
    assessmentDate : LocalDate
  }
  note right of SkillsAssessment : periodic, every 5 years (sec. 3.1.1)
  class SystemUser <<entity>> {
  }
  note left of SystemUser : EAPLI framework boundary.\nStores: email (unique, sec. 3.1.1), name, phoneNumber.\nInternal details managed by the framework.
  Collaborator <|-- ATCCollaborator
  Collaborator <|-- FlightControlOperator
  Collaborator <|-- WeatherPerson
  Collaborator *--- SecurityClearance : hasActive
  Collaborator *--- SkillsAssessment : assessed
  Collaborator -> SystemUser : linkedTo
}


package "WeatherData_Aggregate" <<aggregate>> {
  class WeatherData <<entity>> <<root>> {
    temperatureCelsius : double
    validFrom : LocalDateTime
    validTo : LocalDateTime
  }
  note right of WeatherData : US042: "data might be from\nmultiple external providers".\nClient: uses validFrom/validTo pair.
  class WindCondition <<value object>> {
    directionDegrees : int
    speedKnots : double
  }
  class WeatherSubArea <<value object>> {
    minLat : double
    maxLat : double
    minLon : double
    maxLon : double
  }
  note right of WeatherSubArea : Weather sub-rectangle inside the ACA.\n"weather not same everywhere in area"
  WeatherData *-- WindCondition : records
  WeatherData *-- WeatherSubArea : coversSubArea
}


package "Simulation_Aggregate" <<aggregate>> {
  class Simulation <<entity>> <<root>> {
    id : Long
  }
  class SimulationTimeRange <<value object>> {
    startDateTime : LocalDateTime
    endDateTime : LocalDateTime
  }
  note right of SimulationTimeRange : Invariant: start < end
  class SafetyThreshold <<value object>> {
    value : double
    unit : String
  }
  note right of SafetyThreshold : value > 0
  class SimulationReport <<value object>> {
    filePath : String
    content : String
  }
  note right of SimulationReport : Stores the SCOMP output file verbatim.\nfilePath: original file path.\ncontent: full text content (CLOB).\nImmutable.
  enum ValidationResult {
    PASSED
    FAILED
    PENDING
  }

  Simulation *-- SimulationTimeRange : scheduledFor
  Simulation *-- SafetyThreshold : boundedBy
  Simulation *-- SimulationReport : produces
  Simulation --> ValidationResult : concludes
}


Airport "*" --> "1" AirControlArea : locatedIn >
Collaborator "*" ---> "0..1" AirControlArea : worksFor >
note on link : Only applicable to FCO and WeatherPerson.\nATCCollaborator always null.


WeatherData "*" --> "1" AirControlArea : registeredFor >

Simulation "*" ----> "1" AirControlArea : covers >


@enduml
