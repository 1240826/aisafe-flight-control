<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
    <VBox spacing="20" style="-fx-background-color: #0d1117; -fx-padding: 24;">
        <VBox spacing="4">
            <Label text="Manufacturers" style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #f0f6fc;" />
            <Label text="Register aircraft and engine manufacturers" style="-fx-font-size: 13px; -fx-text-fill: #8b949e;" />
        </VBox>

        <TextField fx:id="searchField" promptText="Search by manufacturer name or country..." styleClass="search-bar" />

        <HBox alignment="CENTER_RIGHT" spacing="8">
            <Button text="🗑 Remove Selected" onAction="#removeManufacturer" styleClass="btn-danger" />
            <Button text="⛶ Expand" onAction="#onZoom" styleClass="btn-zoom" />
        </HBox>
        <TableView fx:id="manufacturersTable" VBox.vgrow="ALWAYS" prefHeight="240">
            <columns>
                <TableColumn fx:id="colName" text="Manufacturer Name" prefWidth="300" />
                <TableColumn fx:id="colCountry" text="Country" prefWidth="200" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
        </TableView>

        <VBox styleClass="content-card" spacing="16">
            <Label text="Register New Manufacturer" style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #f0f6fc;" />
            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Manufacturer Name" styleClass="form-label" />
                    <TextField fx:id="newName" promptText="e.g. Boeing" styleClass="form-field" />
                    <Label fx:id="newNameError" styleClass="field-error-label" managed="false" visible="false" />
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Country" styleClass="form-label" />
                    <TextField fx:id="newCountry" promptText="e.g. USA" styleClass="form-field" />
                    <Label fx:id="newCountryError" styleClass="field-error-label" managed="false" visible="false" />
                </VBox>
            </HBox>
            <Button text="Register Manufacturer" onAction="#addManufacturer" styleClass="btn-primary" maxWidth="Infinity" />
        </VBox>
    </VBox>
</ScrollPane>
