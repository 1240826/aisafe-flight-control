<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
    <VBox spacing="20" style="-fx-background-color: #0d1117; -fx-padding: 24;">
        <VBox spacing="4">
            <Label text="Test Flight Plans" style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #f0f6fc;" />
            <Label text="Run simulations on imported flight plans" style="-fx-font-size: 13px; -fx-text-fill: #8b949e;" />
        </VBox>

        <!-- Test Plans Table -->
        <VBox styleClass="content-card" spacing="12">
            <Label text="Flight Plans Ready for Testing" style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #f0f6fc;" />
            <TableView fx:id="testPlansTable" prefHeight="450" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colSel" text="✓" prefWidth="40" />
                    <TableColumn fx:id="colNum" text="#" prefWidth="40" />
                    <TableColumn fx:id="colFlight" text="Flight" prefWidth="120" />
                    <TableColumn fx:id="colPlanId" text="Plan ID" prefWidth="120" />
                    <TableColumn fx:id="colRoute" text="Route" prefWidth="200" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            </TableView>
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="🔄 Refresh" onAction="#onRefresh" styleClass="btn-zoom" />
                <Button text="Test Selected" onAction="#onTestSelected" styleClass="btn-primary" />
            </HBox>
        </VBox>

        <!-- Results Section -->
        <VBox fx:id="simulationResult" managed="false" visible="false" styleClass="content-card" spacing="8">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="simulationTitle" text="Simulation" style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #f0f6fc;" HBox.hgrow="ALWAYS" />
                <Button text="💾 Save Report" onAction="#onSaveReport" styleClass="btn-zoom" />
                <Button text="⛶ Expand" onAction="#onZoomReport" styleClass="btn-zoom" />
            </HBox>
            <TextArea fx:id="simulationReport" editable="false" prefHeight="250" styleClass="form-field" />
        </VBox>
    </VBox>
</ScrollPane>
