<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
    <VBox spacing="20" style="-fx-background-color: #0d1117; -fx-padding: 24;">
        <VBox spacing="4">
            <Label text="Import Flight Plan" style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #f0f6fc;" />
            <Label text="Import and validate flight plan DSL files" style="-fx-font-size: 13px; -fx-text-fill: #8b949e;" />
        </VBox>

        <!-- Import DSL Section -->
        <VBox styleClass="content-card" spacing="12">
            <Label text="Flight Plan DSL" style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #f0f6fc;" />
            <HBox spacing="12" alignment="CENTER_LEFT">
                <ComboBox fx:id="exampleSelector" promptText="Load an example..." styleClass="form-field" prefWidth="300" HBox.hgrow="ALWAYS" />
                <Button text="Load Example" onAction="#loadExample" styleClass="btn-secondary" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Browse File..." onAction="#chooseFile" styleClass="btn-outline" />
            </HBox>
            <HBox spacing="12">
                <TextField fx:id="filePathField" promptText="No file selected..." styleClass="form-field" editable="false" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextArea fx:id="dslContent" editable="false" prefHeight="150" styleClass="form-field"
                          promptText="Flight plan DSL content..." HBox.hgrow="ALWAYS" />
                <VBox spacing="8">
                    <Button text="⛶ Expand" onAction="#onZoomDsl" styleClass="btn-zoom" />
                </VBox>
            </HBox>
            <HBox spacing="12">
                <Button text="🔍 Validate &amp; Import" onAction="#importPlan" styleClass="btn-primary" HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>

        <!-- Validation Result -->
        <VBox fx:id="validationResult" managed="false" visible="false" styleClass="content-card" spacing="8">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="validationTitle" text="Validation" style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #f0f6fc;" HBox.hgrow="ALWAYS" />
                <Button text="⛶ Expand" onAction="#onZoomValidation" styleClass="btn-zoom" />
            </HBox>
            <TextArea fx:id="validationDetails" editable="false" prefHeight="80" styleClass="form-field" />
        </VBox>

        <!-- Weather Section -->
        <VBox fx:id="weatherSection" managed="false" visible="false" styleClass="content-card" spacing="12">
            <Label text="Route Weather Data" style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #f0f6fc;" />
            <HBox spacing="12" alignment="CENTER_LEFT">
                <ComboBox fx:id="weatherSelector" promptText="Select weather data..." styleClass="form-field" prefWidth="400" HBox.hgrow="ALWAYS" />
                <Button fx:id="assignWeatherBtn" text="Assign Weather" onAction="#onAssignWeather" styleClass="btn-primary" />
                <Button fx:id="addWeatherNavBtn" text="+ New Weather" onAction="#onAddNewWeather" styleClass="btn-outline" />
            </HBox>
            <Label fx:id="weatherStatus" style="-fx-font-size: 12px; -fx-text-fill: #8b949e;" />
        </VBox>
    </VBox>
</ScrollPane>
