<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
    <VBox spacing="20" style="-fx-background-color: #0d1117; -fx-padding: 24;">
        <VBox spacing="4">
            <Label text="Aircraft Fleet" style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #f0f6fc;" />
            <Label text="Manage aircraft across all air transport companies" style="-fx-font-size: 13px; -fx-text-fill: #8b949e;" />
        </VBox>

        <TextField fx:id="searchField" promptText="Search by registration, model, company or status..." styleClass="search-bar" />

        <HBox spacing="12">
            <ComboBox fx:id="filterModel" promptText="Filter by model" styleClass="form-field" prefWidth="200" />
            <ComboBox fx:id="filterCompany" promptText="Filter by company" styleClass="form-field" prefWidth="200" />
            <ComboBox fx:id="filterStatus" promptText="Filter by status" styleClass="form-field" prefWidth="160" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Refresh" onAction="#refreshTable" styleClass="btn-secondary" />
        </HBox>

        <HBox alignment="CENTER_RIGHT">
            <Button text="⛶ Expand" onAction="#onZoom" styleClass="btn-zoom" />
        </HBox>
        <TableView fx:id="aircraftTable" VBox.vgrow="ALWAYS" prefHeight="240">
            <columns>
                <TableColumn fx:id="colReg" text="Registration" prefWidth="140" />
                <TableColumn fx:id="colModel" text="Model" prefWidth="100" />
                <TableColumn fx:id="colCompany" text="Company" prefWidth="100" />
                <TableColumn fx:id="colCrew" text="Crew" prefWidth="60" />
                <TableColumn fx:id="colCapacity" text="Capacity" prefWidth="80" />
                <TableColumn fx:id="colStatus" text="Status" prefWidth="100" />
            </columns>
        </TableView>

        <VBox styleClass="content-card" spacing="16">
            <Label text="Register New Aircraft" style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #f0f6fc;" />
            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Registration Number" styleClass="form-label" />
                    <TextField fx:id="newReg" promptText="e.g. CS-TUI" styleClass="form-field" />
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Registration Country" styleClass="form-label" />
                    <TextField fx:id="newRegCountry" promptText="e.g. Portugal" styleClass="form-field" />
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Aircraft Model" styleClass="form-label" />
                    <ComboBox fx:id="newModel" styleClass="form-field" promptText="Select model..." HBox.hgrow="ALWAYS" />
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Air Transport Company" styleClass="form-label" />
                    <ComboBox fx:id="newCompany" styleClass="form-field" promptText="Select company..." HBox.hgrow="ALWAYS" />
                </VBox>
            </HBox>
            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Flight Crew" styleClass="form-label" />
                    <TextField fx:id="newCrew" promptText="e.g. 3" styleClass="form-field" />
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Seats (Economy)" styleClass="form-label" />
                    <TextField fx:id="newSeats" promptText="e.g. 180" styleClass="form-field" />
                </VBox>
            </HBox>
            <Button text="Register Aircraft" onAction="#addAircraft" styleClass="btn-primary" maxWidth="Infinity" />
        </VBox>
    </VBox>
</ScrollPane>
