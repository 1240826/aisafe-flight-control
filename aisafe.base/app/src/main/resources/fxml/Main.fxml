<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <HBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <!-- Sidebar -->
        <VBox styleClass="sidebar" minWidth="240" maxWidth="240">
            <!-- Brand Header -->
            <VBox styleClass="sidebar-header" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="✈" style="-fx-font-size: 24px; -fx-text-fill: #58a6ff;" />
                    <VBox spacing="0">
                        <Label text="AISafe" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #f0f6fc;" />
                        <Label text="Flight Control" style="-fx-font-size: 10px; -fx-text-fill: #484f58;" />
                    </VBox>
                </HBox>
                <!-- User Info -->
                <VBox styleClass="sidebar-user" spacing="4">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="👤" style="-fx-font-size: 14px;" />
                        <Label fx:id="userDisplayName" text="User" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #f0f6fc;" />
                    </HBox>
                    <Label fx:id="userRole" text="Role" style="-fx-font-size: 11px; -fx-text-fill: #8b949e; -fx-padding: 0 0 0 22;" />
                </VBox>
            </VBox>

            <!-- Navigation -->
            <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <VBox fx:id="navItems" spacing="0">
                    <!-- Dashboard -->
                    <Button styleClass="nav-item" onAction="#showDashboard">
                        <graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="📊" styleClass="nav-item-icon, icon-dashboard" /><Label text="Dashboard" styleClass="nav-item-text" /></HBox></graphic>
                    </Button>

                    <Separator style="-fx-background-color: #21262d; -fx-padding: 4 16;" />

                    <!-- Admin Section -->
                    <VBox fx:id="adminSection" managed="false" visible="false">
                        <Label text="Administration" styleClass="sidebar-nav-label" />
                        <Button styleClass="nav-item" onAction="#showUsers">
                            <graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="👥" styleClass="nav-item-icon, icon-users" /><Label text="User Management" styleClass="nav-item-text" /></HBox></graphic>
                        </Button>
                        <Separator style="-fx-background-color: #21262d; -fx-padding: 4 16;" />
                    </VBox>

                    <!-- Configuration Section -->
                    <VBox fx:id="backofficeSection" managed="false" visible="false">
                        <Label text="Configuration" styleClass="sidebar-nav-label" />
                        <Button styleClass="nav-item" onAction="#showManufacturers"><graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="🏭" styleClass="nav-item-icon, icon-manufacturer" /><Label text="Manufacturers" styleClass="nav-item-text" /></HBox></graphic></Button>
                        <Button styleClass="nav-item" onAction="#showEngineModels"><graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="⚙️" styleClass="nav-item-icon, icon-engine" /><Label text="Engine Models" styleClass="nav-item-text" /></HBox></graphic></Button>
                        <Button styleClass="nav-item" onAction="#showAircraftModels"><graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="🛩️" styleClass="nav-item-icon, icon-aircraft-model" /><Label text="Aircraft Models" styleClass="nav-item-text" /></HBox></graphic></Button>
                        <Button styleClass="nav-item" onAction="#showAirControlAreas"><graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="🗺️" styleClass="nav-item-icon, icon-air-control" /><Label text="Air Control Areas" styleClass="nav-item-text" /></HBox></graphic></Button>
                        <Button styleClass="nav-item" onAction="#showAirports"><graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="🛫" styleClass="nav-item-icon, icon-airport" /><Label text="Airports" styleClass="nav-item-text" /></HBox></graphic></Button>
                        <Button styleClass="nav-item" onAction="#showAirTransportCompanies"><graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="🏢" styleClass="nav-item-icon, icon-company" /><Label text="Air Transport Companies" styleClass="nav-item-text" /></HBox></graphic></Button>
                        <Button styleClass="nav-item" onAction="#showCollaborators"><graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="🤝" styleClass="nav-item-icon, icon-collaborator" /><Label text="Collaborators" styleClass="nav-item-text" /></HBox></graphic></Button>
                        <Separator style="-fx-background-color: #21262d; -fx-padding: 4 16;" />
                    </VBox>

                    <!-- Fleet Management Section -->
                    <VBox fx:id="fleetSection" managed="false" visible="false">
                        <Label text="Fleet Management" styleClass="sidebar-nav-label" />
                        <Button styleClass="nav-item" onAction="#showAircraft"><graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="🛩️" styleClass="nav-item-icon, icon-aircraft" /><Label text="Aircraft Fleet" styleClass="nav-item-text" /></HBox></graphic></Button>
                        <Button styleClass="nav-item" onAction="#showFlightRoutes"><graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="🛤️" styleClass="nav-item-icon, icon-route" /><Label text="Flight Routes" styleClass="nav-item-text" /></HBox></graphic></Button>
                        <Button styleClass="nav-item" onAction="#showPilots"><graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="👨‍✈️" styleClass="nav-item-icon, icon-pilot" /><Label text="Pilot Roster" styleClass="nav-item-text" /></HBox></graphic></Button>
                        <Separator style="-fx-background-color: #21262d; -fx-padding: 4 16;" />
                    </VBox>

                    <!-- Operations Section -->
                    <VBox fx:id="operationsSection" managed="false" visible="false">
                        <Label text="Flight Operations" styleClass="sidebar-nav-label" />
                        <Button styleClass="nav-item" onAction="#showImportFlightPlan"><graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="📄" styleClass="nav-item-icon, icon-flight-plan" /><Label text="Import Flight Plan" styleClass="nav-item-text" /></HBox></graphic></Button>
                        <Button styleClass="nav-item" onAction="#showTestFlightPlans"><graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="🧪" styleClass="nav-item-icon" /><Label text="Test Flight Plans" styleClass="nav-item-text" /></HBox></graphic></Button>
                        <Separator style="-fx-background-color: #21262d; -fx-padding: 4 16;" />
                    </VBox>

                    <!-- Weather Section -->
                    <VBox fx:id="weatherSection" managed="false" visible="false">
                        <Label text="Weather Service" styleClass="sidebar-nav-label" />
                        <Button styleClass="nav-item" onAction="#showWeatherData"><graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="🌤️" styleClass="nav-item-icon, icon-weather" /><Label text="Weather Data" styleClass="nav-item-text" /></HBox></graphic></Button>
                        <Separator style="-fx-background-color: #21262d; -fx-padding: 4 16;" />
                    </VBox>

                    <!-- Pilot Section -->
                    <VBox fx:id="pilotSection" managed="false" visible="false">
                        <Label text="Pilot Tools" styleClass="sidebar-nav-label" />
                        <Button styleClass="nav-item" onAction="#showImportFlightPlan"><graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="📄" styleClass="nav-item-icon, icon-flight-plan" /><Label text="Import Flight Plan" styleClass="nav-item-text" /></HBox></graphic></Button>
                        <Separator style="-fx-background-color: #21262d; -fx-padding: 4 16;" />
                    </VBox>

                    <!-- Reports Section -->
                    <VBox fx:id="reportsSection" managed="false" visible="false">
                        <Label text="Reports &amp; Analysis" styleClass="sidebar-nav-label" />
                        <Button styleClass="nav-item" onAction="#showReports"><graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="📈" styleClass="nav-item-icon, icon-reports" /><Label text="Monthly Reports" styleClass="nav-item-text" /></HBox></graphic></Button>
                        <Button styleClass="nav-item" onAction="#showSimulationReports"><graphic><HBox spacing="10" alignment="CENTER_LEFT"><Label text="📋" styleClass="nav-item-icon, icon-simulation" /><Label text="Simulation Reports" styleClass="nav-item-text" /></HBox></graphic></Button>
                        <Separator style="-fx-background-color: #21262d; -fx-padding: 4 16;" />
                    </VBox>
                </VBox>
            </ScrollPane>
        </VBox>

        <!-- Main Content -->
        <VBox HBox.hgrow="ALWAYS">
            <!-- Top Bar -->
            <HBox styleClass="top-bar">
                <Label fx:id="currentViewTitle" text="Dashboard" styleClass="top-bar-title" HBox.hgrow="ALWAYS" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox styleClass="system-status" spacing="6">
                    <Label text="●" style="-fx-text-fill: #3fb950; -fx-font-size: 10px;" />
                    <Label text="System Ready" styleClass="system-status-text" />
                </HBox>
                <HBox spacing="4" style="-fx-padding: 0 0 0 12;">
                    <Button onAction="#showSettings" styleClass="btn-icon-settings">
                        <graphic><HBox spacing="4" alignment="CENTER_LEFT"><Label text="⚙" styleClass="icon-settings" /><Label text="Settings" styleClass="btn-icon-label" /></HBox></graphic>
                    </Button>
                    <Button onAction="#handleLogout" styleClass="btn-icon-logout">
                        <graphic><HBox spacing="4" alignment="CENTER_LEFT"><Label text="🚪" styleClass="icon-logout" /><Label text="Sign Out" styleClass="btn-icon-label" /></HBox></graphic>
                    </Button>
                </HBox>
            </HBox>

            <!-- Content Area -->
            <AnchorPane fx:id="contentArea" styleClass="content-area" VBox.vgrow="ALWAYS" />
        </VBox>
    </HBox>
</AnchorPane>
