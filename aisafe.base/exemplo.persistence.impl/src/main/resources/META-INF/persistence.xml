<?xml version="1.0" encoding="UTF-8"?>
<persistence version="2.1" xmlns="http://xmlns.jcp.org/xml/ns/persistence">
  <persistence-unit name="eapli.exemplo">
    <!--
    <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
    -->
    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

    <class>eapli.framework.infrastructure.authz.domain.model.SystemUser</class>
    <class>eapli.framework.infrastructure.authz.domain.model.Role</class>
    <class>eapli.framework.infrastructure.authz.domain.model.RoleSet</class>
    <class>eapli.framework.infrastructure.authz.domain.model.RoleAssignment</class>
    <class>eapli.exemplo.utentemanagement.domain.Utente</class>
    <class>eapli.exemplo.utentemanagement.domain.SignupRequest</class>

    <!-- AISafe entities -->
    <class>eapli.aisafe.usermanagement.domain.UserSecurityProfile</class>
    <class>eapli.aisafe.manufacturer.domain.Manufacturer</class>
    <class>eapli.aisafe.enginemodel.domain.EngineModel</class>
    <class>eapli.aisafe.aircraftmodel.domain.AircraftModel</class>
    <class>eapli.aisafe.aircraftmodel.domain.AircraftVariant</class>
    <class>eapli.aisafe.aircraft.domain.Aircraft</class>
    <class>eapli.aisafe.aircontrolarea.domain.AirControlArea</class>
    <class>eapli.aisafe.airport.domain.Airport</class>
    <class>eapli.aisafe.company.domain.AirTransportCompany</class>
    <class>eapli.aisafe.collaborator.domain.Collaborator</class>
    <class>eapli.aisafe.collaborator.domain.ATCCollaborator</class>
    <class>eapli.aisafe.collaborator.domain.FlightControlOperator</class>
    <class>eapli.aisafe.collaborator.domain.WeatherPerson</class>
    <class>eapli.aisafe.weatherdata.domain.WeatherData</class>

    <properties>
      <!--<property name="jakarta.persistence.jdbc.url" value="jdbc:h2:tcp://localhost/~/eapliexemplo"/>-->
      <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:~\eapliexemplo"/>

      <property name="jakarta.persistence.jdbc.user" value="sa"/>
      <property name="jakarta.persistence.jdbc.password" value=""/>
      <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
      <!-- <property name="jakarta.persistence.schema-generation.database.action" value="drop-and-create"/> -->
      <!-- <property name="eclipselink.logging.level" value="FINE"/> -->
      <!-- <property name = "hibernate.show_sql" value = "true" /> -->
      <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect"/>

    </properties>
  </persistence-unit>
</persistence>